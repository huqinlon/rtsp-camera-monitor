# ============================================
# Docker Build 排除文件
# ============================================

# Git
.git
.gitignore

# IDE和编辑器
.idea/
.vscode/
*.swp
*.swo
*~

# Python缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# 测试文件
test_*.py
*.test.py

# 文档
# *.md
docs/

# Docker相关（避免循环引用）
Dockerfile*
docker-compose*.yml
.docker/

# 本地数据（应该在运行时挂载）
data/
screenshots/
videos/
lowfps/
logs/

# 系统文件
.DS_Store
Thumbs.db

# 临时文件
*.tmp
*.temp
*.log
